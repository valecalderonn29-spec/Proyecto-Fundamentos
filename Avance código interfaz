def Ajustar_color(color_hex, factor=0.88):
    """Oscurece un color hexadecimal para el efecto hover."""
    if not color_hex.startswith('#') or len(color_hex) != 7:
        return color_hex
    try:
        r = int(color_hex[1:3], 16)
        g = int(color_hex[3:5], 16)
        b = int(color_hex[5:7], 16)
    except ValueError:
        return color_hex

    def clamp(value):
        return max(0, min(255, int(value)))

    r = clamp(r * factor)
    g = clamp(g * factor)
    b = clamp(b * factor)
    return f'#{r:02x}{g:02x}{b:02x}'


def Crear_boton(padre, texto, comando, bg_color=COLOR_ACENTO, fg_color=COLOR_TEXTO, ancho=24,
                 font=FONT_MEDIANA, padx=18, pady=10, **kwargs):
    hover_bg = Ajustar_color(bg_color, 0.90)
    btn = Button(padre, text=texto, command=comando,
                 bg=bg_color, fg=fg_color,
                 font=font, relief=FLAT,
                 activebackground=hover_bg, activeforeground=COLOR_TEXTO,
                 bd=0, highlightthickness=0, padx=padx, pady=pady, width=ancho,
                 cursor='hand2', **kwargs)
    default_bg = bg_color
    btn.bind("<Enter>", lambda e, b=btn: b.config(bg=hover_bg))
    btn.bind("<Leave>", lambda e, b=btn, bg=default_bg: b.config(bg=default_bg))
    return btn


def Crear_contenedor_scrollable(padre):
    frame_scroll = Frame(padre, bg=BG)
    canvas = Canvas(frame_scroll, bg=BG, highlightthickness=0)
    scrollbar = Scrollbar(frame_scroll, orient=VERTICAL, command=canvas.yview)
    inner_frame = Frame(canvas, bg=BG)

    window_id = canvas.create_window((0, 0), window=inner_frame, anchor='nw')
    inner_frame.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
    canvas.bind("<Configure>", lambda e: canvas.itemconfig(window_id, width=e.width))
    canvas.configure(yscrollcommand=scrollbar.set)

    canvas.pack(side=LEFT, fill=BOTH, expand=True)
    scrollbar.pack(side=RIGHT, fill=Y)
    return frame_scroll, inner_frame

