Frm_botones_trans.pack(pady=(10, 20))

def FUNC_Btn_confirmar_respuesta():
    if juego_transmision_activo and respuesta_teclado_trans.strip():
        Finalizar_ronda_transmision()

Btn_confirmar = Crear_boton(Frm_botones_trans, '✓ CONFIRMAR RESPUESTA', FUNC_Btn_confirmar_respuesta, bg_color=COLOR_VERDE, fg_color=BG)
Btn_confirmar.pack(side=LEFT, padx=8)

def FUNC_Btn_volver_menu():
    if messagebox.askyesno("Confirmar", "¿Volver al menú principal? Se perderá el progreso actual."):
        CambiarPantalla(Contenedor_Pantalla_Menu)

Btn_volver_menu = Crear_boton(Frm_botones_trans, '← MENÚ', FUNC_Btn_volver_menu, bg_color=COLOR_ACENTO2)
Btn_volver_menu.pack(side=LEFT, padx=8)

def Actualizar_display_teclado_trans():
    global respuesta_teclado_trans
    secuencia = ''.join(tec_simbolos_trans)

    if secuencia:
        texto_simbolos = secuencia
        texto_char = Decodificar_simbolo(secuencia)
    else:
        texto_simbolos = "·"
        texto_char = ""

    texto_actual = ''.join(tec_texto_trans)
    Lbl_texto_trans.config(text=texto_actual)
    respuesta_teclado_trans = texto_actual

def Confirmar_caracter_trans():
    global tec_timer_char_trans

    if tec_timer_char_trans is not None:
        VENTANA.after_cancel(tec_timer_char_trans)
        tec_timer_char_trans = None

    secuencia = ''.join(tec_simbolos_trans)
    if secuencia:
        char = Decodificar_simbolo(secuencia)
        tec_texto_trans.append(char)
        tec_simbolos_trans.clear()
        Lbl_estado_trans.config(text=f'{secuencia} → {char}', fg=COLOR_VERDE)
    Actualizar_display_teclado_trans()

def Confirmar_palabra_trans():
    global tec_timer_palabra_trans
    tec_timer_palabra_trans = None
    Confirmar_caracter_trans()

    if tec_texto_trans and tec_texto_trans[-1] != ' ':
        tec_texto_trans.append(' ')

    Actualizar_display_teclado_trans()
    Lbl_estado_trans.config(text='ENTER para confirmar respuesta, ESPACIO para continuar editando', fg=COLOR_AMARILLO)

    # Vincular ENTER para confirmar respuesta
    VENTANA.bind("<Return>", lambda e: Finalizar_ronda_transmision())

def Espacio_presionado_trans(evento):
    global tec_presionado_trans, tec_t_inicio_trans
    global tec_timer_char_trans, tec_timer_palabra_trans
    if tec_presionado_trans:
        return

    if tec_timer_char_trans is not None:
        VENTANA.after_cancel(tec_timer_char_trans)
        tec_timer_char_trans = None

    if tec_timer_palabra_trans is not None:
        VENTANA.after_cancel(tec_timer_palabra_trans)
        tec_timer_palabra_trans = None

    tec_presionado_trans = True
    tec_t_inicio_trans = time.time()
    Lbl_estado_trans.config(text='● Presionando...', fg=COLOR_ACENTO)

def Espacio_al_soltar_trans(evento):
    global tec_presionado_trans, tec_timer_char_trans, tec_timer_palabra_trans

    if not tec_presionado_trans:
        return

    duracion = time.time() - tec_t_inicio_trans
    tec_presionado_trans = False
    unidad = Get_unidad()

    if duracion < unidad * 2:
        simbolo = '.'
    else:
        simbolo = '-'

    tec_simbolos_trans.append(simbolo)
    Actualizar_display_teclado_trans()

    if simbolo == '.':
        Lbl_estado_trans.config(text=f'Punto ({duracion:.2f}s)', fg=COLOR_GRIS)
    else:
        Lbl_estado_trans.config(text=f'Raya ({duracion:.2f}s)', fg=COLOR_GRIS)

    tec_timer_char_trans = VENTANA.after(int(unidad * 3 * 1000), Confirmar_caracter_trans)
    tec_timer_palabra_trans = VENTANA.after(int(unidad * 7 * 1000), Confirmar_palabra_trans)

VENTANA.bind("<KeyPress-space>", Espacio_presionado_trans)
VENTANA.bind("<KeyRelease-space>", Espacio_al_soltar_trans)

VENTANA.mainloop()
