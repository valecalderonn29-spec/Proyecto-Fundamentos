def Calcular_puntos_transmision(objetivo, respuesta, velocidad):
    """Calcula puntos considerando la velocidad (mayor velocidad = más puntos)"""
    puntos_base = Calcular_puntos(objetivo, respuesta)
    multiplicador_velocidad = velocidad  # 1x, 2x, 3x
    return puntos_base * multiplicador_velocidad

