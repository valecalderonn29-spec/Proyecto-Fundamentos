def Iniciar_transmision_ronda(evento):
    """Inicia la transmisión de la frase actual por parte de la Pico W"""
    global juego_transmision_activo

    if juego_transmision_activo:
        return

    juego_transmision_activo = True
    Lbl_estado_trans.config(text='Transmitiendo frase...', fg=COLOR_AMARILLO)

    # Enviar comando para que la Pico transmita la frase actual a la velocidad actual
    comando = f'TRANSMITIR/{frase_actual_trans}/{velocidad_actual}'
    respuesta = Enviar_comando(comando)

    if respuesta:
        Lbl_estado_trans.config(text='Transmisión completada. Ahora ingresa tu respuesta con ESPACIO', fg=COLOR_VERDE)
        # Configurar entrada del usuario
        VENTANA.bind("<KeyPress-space>", Espacio_presionado_trans)
        VENTANA.bind("<KeyRelease-space>", Espacio_al_soltar_trans)
    else:
        Lbl_estado_trans.config(text='Error en transmisión. Verifica conexión con Pico W', fg=COLOR_ACENTO)
        juego_transmision_activo = False

def Finalizar_ronda_transmision():
    """Calcula puntaje de la ronda actual y pasa a la siguiente"""
    global ronda_trans, velocidad_actual, juego_transmision_activo

    # Calcular puntaje
    objetivo = frase_actual_trans.replace(' ', '').upper()
    respuesta = respuesta_teclado_trans.replace(' ', '').upper()
    puntos = Calcular_puntos_transmision(objetivo, respuesta, velocidad_actual)
    puntajes_transmision[ronda_trans - 1] = puntos

    # Mostrar resultado de ronda
    messagebox.showinfo("Resultado de Ronda",
                       f"Ronda {ronda_trans}/3 completada\n"
                       f"Frase: {frase_actual_trans}\n"
                       f"Tu respuesta: {respuesta_teclado_trans}\n"
                       f"Puntos: {puntos} (x{velocidad_actual})")

    ronda_trans += 1
    juego_transmision_activo = False

    if ronda_trans <= 3:
        # Preparar siguiente ronda
        velocidad_actual = ronda_trans  # 1x, 2x, 3x
        frase_actual_trans = random.choice(PALABRAS)

        Lbl_titulo_trans.config(text=f'RONDA {ronda_trans}/3 - Velocidad: {velocidad_actual}x')
        Lbl_frase_trans.config(text=frase_actual_trans)
        Lbl_texto_trans.config(text='')
        Lbl_estado_trans.config(text='Presiona ESPACIO para comenzar la siguiente ronda', fg=COLOR_GRIS)

        # Limpiar entrada
        tec_simbolos_trans.clear()
        tec_texto_trans.clear()

        VENTANA.bind("<KeyPress-space>", Iniciar_transmision_ronda)
        VENTANA.unbind("<KeyRelease-space>")
    else:
        # Juego completado - mostrar resultados finales
        Mostrar_resultados_transmision()

