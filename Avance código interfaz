PALABRAS_DEFECTO = ["SOS", "SI", "NO", "POLLO", "PERRO", "CE1104", "AMOR", "PYTHON", "TEC", "ELEVEN"]

def Cargar_frases():
    if os.path.exists(ARCHIVO_FRASES):
        try:
            with open(ARCHIVO_FRASES, 'r', encoding='utf-8') as f:
                data = json.load(f)
                return data if isinstance(data, list) and len(data) > 0 else PALABRAS_DEFECTO.copy()
        except:
            return PALABRAS_DEFECTO.copy()
    return PALABRAS_DEFECTO.copy()

def Guardar_frases(frases):
    frases = [f.strip().upper()[:16] for f in frases if f.strip()]
    while len(frases) < 10:
        frases.append(f"FRASE{len(frases)+1}")
    with open(ARCHIVO_FRASES, 'w', encoding='utf-8') as f:
        json.dump(frases[:10], f, ensure_ascii=False, indent=2)

def Cargar_puntajes():
    if os.path.exists(ARCHIVO_PUNTAJES):
        try:
            with open(ARCHIVO_PUNTAJES, 'r', encoding='utf-8') as f:
                return json.load(f)
        except:
            return []
    return []

def Guardar_puntajes(puntajes):
    with open(ARCHIVO_PUNTAJES, 'w', encoding='utf-8') as f:
        json.dump(puntajes, f, ensure_ascii=False, indent=2)

def Agregar_puntaje(nombre, puntos, modo, ronda):
    puntajes = Cargar_puntajes()
    puntajes.append({
        "nombre": nombre,
        "puntos": puntos,
        "modo": modo,
        "ronda": ronda,
        "fecha": time.strftime("%Y-%m-%d %H:%M:%S")
    })
    puntajes.sort(key=lambda x: x["puntos"], reverse=True)
    puntajes = puntajes[:10]
    Guardar_puntajes(puntajes)
    return puntajes

